DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-in-production

ALLOWED_HOSTS=fortprint.com.ua,www.fortprint.com.ua
CSRF_TRUSTED_ORIGINS=https://fortprint.com.ua,https://www.fortprint.com.ua
SECURE_SSL_REDIRECT=True

# --- DigitalOcean / Docker (PostgreSQL) ---
DB_ENGINE=postgresql
POSTGRES_DB=fortunaprint
POSTGRES_USER=fortunaprint
POSTGRES_PASSWORD=strong-password-here
DB_HOST=db
DB_PORT=5432

